    {
      "type": "text",
      "id": "ext_t",
      "x": 248.59999999999997,
      "y": 717.75,
      "width": 562.8000000000001,
      "height": 84.5,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
